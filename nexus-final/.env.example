PORT=3000
NODE_ENV=development

# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_isso_por_uma_chave_secreta_muito_longa_em_producao
JWT_EXPIRES_IN=8h

# Em produção: CORS_ORIGIN=https://seusite.com.br
CORS_ORIGIN=*
